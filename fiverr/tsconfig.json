{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "app/seller/orders/page.jsx",
    "app/messages/[orderId]/page.jsx",
    "app/search/page.jsx",
    "app/success/page.jsx",
    "app/layout.jsx",
    "app/page.jsx",
    "app/components/Navbar.jsx",
    "app/components/Footer.jsx",
    "app/admin/users/page.jsx",
    "app/admin/reports/page.jsx",
    "app/admin/orders/page.jsx",
    "app/admin/gigs/page.jsx",
    "app/admin/dashboard/page.jsx"
  ],
  "exclude": [
    "node_modules"
  ]
}